# DATA FILES - Don't upload datasets
data/raw/*.csv
data/raw/*.xlsx
data/processed/*.npy

# Keep folders but not files
!data/raw/.gitkeep
!data/processed/.gitkeep

# MODEL FILES - Allow trained models (needed by backend for deployment)
# models/*.pkl

# RESULT FILES - Don't upload generated results
results/*.csv
results/plots/*.png

